  "ingredients": [
    {
      "name": "Alcohol Ethoxylate",
      "slug": "alcohol-ethoxylate",
      "aliases": [
        "C9-11 Alcohol Ethoxylate 6 Mole"
      ],
      "description": "Non‑ionic surfactant used to remove grease and oily soils; improves wetting and detergency.",
      "id": "ing_alcohol-ethoxylate"
    },
    {
      "name": "Aqua",
      "slug": "aqua",
      "aliases": [],
      "description": "Aqua (H2O) is a universal solvent in cosmetics. It is naturally combined with thick ingredients like oils and butters to form lotions and creams. In skin care, aqua dissolves these ingredients and facilitates the making of lighter products that can be applied evenly and rinsed off with ease.",
      "id": "ing_aqua"
    },
    {
      "name": "Argan Oil",
      "slug": "argan-oil",
      "aliases": [
        "Argania Spinosa Kernel Oil"
      ],
      "description": "Non‑fragrant plant oil rich in fatty acids and tocopherols; conditions skin and hair and adds emollience.",
      "id": "ing_argan-oil"
    },
    {
      "name": "Carboxymethyl Cellulose",
      "slug": "carboxymethyl-cellulose",
      "aliases": [
        "CMC",
        "Sodium Carboxymethylcellulose"
      ],
      "description": "Cellulose‑derived polymer that thickens, suspends and helps prevent soil redeposition in detergents.",
      "id": "ing_carboxymethyl-cellulose"
    },
    {
      "name": "Carnauba Wax",
      "slug": "carnauba-wax",
      "aliases": [],
      "description": "Hard natural wax from Copernicia prunifera leaves; adds gloss and structure and helps with film formation.",
      "id": "ing_carnauba-wax"
    },
    {
      "name": "Cetearyl Alcohol",
      "slug": "cetearyl-alcohol",
      "aliases": [
        "Cetostearyl Alcohol"
      ],
      "description": "A fatty alcohol blend (cetyl + stearyl) that thickens and stabilises emulsions and improves slip.",
      "id": "ing_cetearyl-alcohol"
    },
    {
      "name": "Cetyl Alcohol",
      "slug": "cetyl-alcohol",
      "aliases": [],
      "description": "Cetyl Alcohol is a universal ingredient in haircare products made from vegetable oil such as palm or coconut oil. It has an added ability to retain moisture, improve texture, and combat common hair woes like frizz and tangles.",
      "id": "ing_cetyl-alcohol"
    },
    {
      "name": "Cocamidopropyl Betaine",
      "slug": "cocamidopropyl-betaine",
      "aliases": [],
      "description": "(CAPB) is a surfactant derived from coconut oil. It is also a foam enhancer and is used in numerous personal care products like shampoos, conditioners, body washes, mouthwashes, cleansers, etc.",
      "id": "ing_cocamidopropyl-betaine"
    },
    {
      "name": "Coco Caprylate",
      "slug": "coco-caprylate",
      "aliases": [],
      "description": "Coco Caprylate is a natural emollient and skin conditioning agent derived from coconut oil. It is commonly used in preparations as a lightweight alternative to mineral oil or silicones, providing a silky, non-greasy feel to the skin.",
      "id": "ing_coco-caprylate"
    },
    {
      "name": "Glyceryl Caprylate",
      "slug": "glyceryl-caprylate",
      "aliases": [],
      "description": "Glyceryl Caprylate is an emollient and conditioning agent derived from glycerin and caprylic acid. It acts as a moisturiser and skin-conditioning agent, helping to soften and hydrate the skin. The antimicrobial properties found in the Glyceryl Caprylate help preserve the product.",
      "id": "ing_glyceryl-caprylate"
    },
    {
      "name": "Grapeseed Oil",
      "slug": "grapeseed-oil",
      "aliases": [
        "Vitis Vinifera (Grapeseed) Oil",
        "Vitis Vinifera Oil"
      ],
      "description": "Light, fast‑absorbing oil from Vitis vinifera seeds; antioxidant‑rich and skin‑conditioning.",
      "id": "ing_grapeseed-oil"
    },
    {
      "name": "Hydrogen Peroxide",
      "slug": "hydrogen-peroxide",
      "aliases": [],
      "description": "Oxygen‑based oxidiser/bleach that removes stains and provides antimicrobial action; water‑safe when used correctly.",
      "id": "ing_hydrogen-peroxide"
    },
    {
